<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F0F4F8">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Paradisuri"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#1A237E"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Locurile tale de vis"
        android:textSize="14sp"
        android:textColor="#9E9E9E"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/tvPlaceholder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Niciun paradis adaugat inca.\nApasa butonul de mai jos pentru a adauga."
        android:textColor="#9E9E9E"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_gravity="center"
        android:padding="16dp"/>

    <ListView
        android:id="@+id/listViewParadisuri"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone"
        android:divider="#E0E0E0"
        android:dividerHeight="1dp"/>

    <Button
        android:id="@+id/btnAdauga"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="+ Adauga Paradis"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#1A237E"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"/>

</LinearLayout>